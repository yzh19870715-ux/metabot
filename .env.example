# =============================================================================
# MetaBot Configuration Template
# =============================================================================

# Feishu Bot Configuration (single-bot mode)
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET

# Claude Code Configuration
CLAUDE_EXECUTABLE_PATH=/opt/homebrew/bin/claude

# MiniMax API 认证
ANTHROPIC_AUTH_TOKEN=YOUR_ANTHROPIC_AUTH_TOKEN
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic/v1
ANTHROPIC_MODEL=MiniMax-M2.7-highspeed

# 默认工作目录
CLAUDE_DEFAULT_WORKING_DIRECTORY=/Users/m4/metabot-workspace

# 禁用遥测
DISABLE_TELEMETRY=1

# HTTP API
API_PORT=9100

# MetaMemory
META_MEMORY_URL=http://localhost:8100

# Logging
LOG_LEVEL=info
